# .env.example — modelo de variáveis de ambiente do Gypsy
#
# Copie para .env e preencha. O .env NUNCA é versionado (ver .gitignore).
# Nenhum segredo real aqui — só nomes e formato. Não há código ainda; esta lista
# cresce conforme o scaffold (backend Django, frontend Vite) chegar.

# --- Backend (Django + PostgreSQL) — preenchidos no scaffold ---
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DATABASE_URL=postgres://user:password@localhost:5432/gypsy

# --- Frontend (Vite) — preenchidos no scaffold ---
# VITE_API_BASE_URL=http://localhost:8000/api
