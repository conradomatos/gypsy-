{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-git-push.py\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git ls-files:*)",
      "Bash(ls:*)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --mirror:*)",
      "Bash(git push --all:*)",
      "Bash(git -c:*)",
      "Bash(git remote add:*)",
      "Bash(git remote set-url:*)",
      "Bash(git remote rename:*)",
      "Bash(git remote remove:*)",
      "Bash(git remote set-branches:*)",
      "Read(.env)",
      "Read(./.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Grep(**/.env*)",
      "Read(destilacao/fontes/**)",
      "Read(./destilacao/fontes/**)",
      "Grep(destilacao/fontes/**)",
      "Write(destilacao/fontes/**)",
      "Write(./destilacao/fontes/**)",
      "Edit(destilacao/fontes/**)",
      "Edit(./destilacao/fontes/**)"
    ]
  }
}
